<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>cafe.pulse.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>__REPO_DIR__/scripts/start_pulse_daemon.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__REPO_DIR__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>__HOME_DIR__/.pulse/logs/launchd.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME_DIR__/.pulse/logs/launchd.error.log</string>
</dict>
</plist>
